APP_NAME=DI_TRAVEL_API
APP_ENV=development
API_PREFIX=/api
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP for forgot-password email
# Use the email account that will send the OTP mail
SMTP_EMAIL=your-smtp-email@example.com
# Use an app password or SMTP password, not your normal login password
SMTP_PASSWORD=your-smtp-password

# Optional: SePay
SEPAY_WEBHOOK_SECRET=
SEPAY_API_TOKEN=

# Optional admin bootstrap
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=DiTravel Admin
ADMIN_PHONE=
